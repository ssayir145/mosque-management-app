# Neon Postgres connection string
# Get this from https://console.neon.tech after creating a project & database
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/mosque?sslmode=require

# Secret used to sign JWTs - generate a long random string, e.g. `openssl rand -hex 32`
JWT_SECRET=replace-with-a-long-random-secret

# Optional: token expiry (jsonwebtoken "expiresIn" format)
JWT_EXPIRES_IN=7d
